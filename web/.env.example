# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:3001

# Stripe publishable key (for Stripe Payment Element)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PayPal client ID (for PayPal JS SDK)
VITE_PAYPAL_CLIENT_ID=...

# ── Analytics (optional — both default to disabled if unset) ──────────────────
# Google Analytics 4 — get from GA4 Admin > Data Streams > Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog — get from posthog.com > Project Settings > Project API Key
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com
