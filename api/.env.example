NODE_ENV=production
PORT=3001

# PostgreSQL — when running via docker-compose, host is "db" (the service name)
# Must match DB_PASSWORD in the root .env file
DATABASE_URL=postgres://tradicore:changeme@db:5432/tradicore

# JWT — generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex

# Frontend URL — used in password-reset email links
APP_URL=https://tradicoreusa.com

# Resend — get your API key from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sending addresses (must be on your Resend-verified domain)
FROM_NOREPLY=no-reply@mail.tradicoreusa.com
FROM_SALES=TradiCore Sales <sales@mail.tradicoreusa.com>

# Where internal notification emails are delivered (your team inboxes)
TEAM_EMAIL=info@tradicoreusa.com
HARDWOOD_EMAIL=hardwood@tradicoreusa.com
SALES_EMAIL=sales@tradicoreusa.com

# Reply-To on all inbound notifications — when a team member hits Reply in Gmail
# this is where it goes. Set to a Gmail/forwarding address until real inboxes exist.
REPLY_TO=tradicoreusa@gmail.com

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://tradicoreusa.com,https://www.tradicoreusa.com,https://firstgoldenlogistics.com,https://www.firstgoldenlogistics.com

# First Golden Logistics
# Recipients for FGL contact form submissions (comma-separated)
FGL_TEAM_EMAILS=yp@firstgoldenlogistics.com,mohammad@firstgoldenlogistics.com,dex@firstgoldenlogistics.com
# Once firstgoldenlogistics.com is verified in Resend, swap these:
# FGL_FROM_NOREPLY=no-reply@mail.firstgoldenlogistics.com
# FGL_FROM_SALES=First Golden Logistics <sales@mail.firstgoldenlogistics.com>
