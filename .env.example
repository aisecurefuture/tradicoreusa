# Copy to .env and fill in before deploying
# Never commit .env to git

# Your domain — Caddy will auto-provision a Let's Encrypt cert for this
DOMAIN=tradicoreusa.com

# PostgreSQL password for the db service
# Must match DATABASE_URL in api/.env (the part after the second colon)
DB_PASSWORD=changeme

# Vite build-time env vars (prefix with VITE_ to expose to the browser)
# VITE_API_URL=https://api.tradicoreusa.com
