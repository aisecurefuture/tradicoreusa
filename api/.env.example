NODE_ENV=production
PORT=3001

# Resend — get your API key from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sending addresses (must be on your Resend-verified domain)
FROM_NOREPLY=no-reply@mail.tradicoreusa.com
FROM_SALES=TradiCore Sales <sales@mail.tradicoreusa.com>

# Where internal notification emails are delivered (your team inboxes)
TEAM_EMAIL=info@tradicoreusa.com
HARDWOOD_EMAIL=hardwood@tradicoreusa.com
SALES_EMAIL=sales@tradicoreusa.com

# Reply-To on all inbound notifications — when a team member hits Reply in Gmail
# this is where it goes. Set to a Gmail/forwarding address until real inboxes exist.
REPLY_TO=tradicoreusa@gmail.com

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://tradicoreusa.com,https://www.tradicoreusa.com
